    <head>
        <title>Gamebar - Home</title>
        <style>
            .game-button {
                width: 150px;
                height: 150px;
                background-color: #172222;
                border: solid 1px #4d664d;
                border-radius: 5px;
                cursor: pointer;
                margin: 5px;
                padding: 0px;
                overflow: hidden;
            }

            .game-labels {
                background-color: #0f0f0f;
            }

            .label-box {
                width: 155px;
                height: 20px;
                text-align: center;
                position: absolute;
                white-space: normal;
                overflow-wrap: break-word;
                word-break: break-all;
            }

            .button-divs {
                display: inline-block;
            }

            .button-images {
                width: 150px;
                height: 150px;
                object-fit: cover;
                border-radius: 5px;
                pointer-events: none;
                display: block;
            }

            #changelog {
                width: 80px;
                height: 80px;
                border: solid 2px #4d664d;
                border-radius: 40px;
            }

            #changelog img {
                width: 80px;
                height: 80px;
            }

            #changelog-button-div {
                position: absolute;
                bottom: 30px;
                left: 20px;
            }

            #partials-header-version {
                right: 840px;
                top: 29px;
            }
        </style>
    </head>

    <body>

        <!-- CHANGELOG BUTTON -->
        <div id="changelog-button-div">
            <button class="game-button" id="changelog" onclick="location.href='/changes'"><img
                    src="index/file.png"></button>
        </div>

    </body>
    <script>
        function Button(route, img, text) {
            this.route = route;
            this.img = img;
            this.text = text;
        }

        var buttons = [
            new Button('/2048', '2048/logo2048.png', '2048'),
            new Button('/snake', 'snake/logoSnake.png', 'Snake'),
            new Button('/stack', 'stack/logoStack.png', 'Stack'),
            new Button('/alchemy', 'index/testing.png', 'Alchemy')
        ];

        buttons.forEach(button => {
            var buttonDiv = document.createElement('div');
            buttonDiv.className = 'button-divs';

            var buttonElement = document.createElement('button');
            buttonElement.className = 'game-button';
            buttonElement.onclick = () => location.href = button.route;

            var imgElement = document.createElement('img');
            imgElement.className = 'button-images';
            imgElement.src = button.img;
            buttonElement.appendChild(imgElement);

            var labelBox = document.createElement('div');
            labelBox.className = 'label-box';

            var label = document.createElement('span');
            label.className = 'game-labels';
            if (button.text.length >= 18) {
                var fullText = button.text;
                button.text = fullText.substring(0, 15) + '...';
            } else {
                var fullText = button.text;
            }
            label.innerHTML = button.text;
            labelBox.appendChild(label);
            buttonDiv.appendChild(buttonElement);
            buttonDiv.appendChild(labelBox);

            buttonElement.addEventListener('mouseover', () => {
                buttonElement.style.transform = 'scale(0.95)';
                buttonElement.style.boxShadow = '0 0 10px #4d664d';
                labelBox.style.height = '100px';
                label.innerHTML = fullText;
            });
            buttonElement.addEventListener('mouseout', () => {
                buttonElement.style.transform = 'scale(1)';
                buttonElement.style.boxShadow = 'none';
                labelBox.style.height = '20px';
                label.innerHTML = button.text;
            });




            document.body.appendChild(buttonDiv);
        });

